# Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# URL pública de la app (sin trailing slash)
VITE_APP_URL=https://misillon.com

# Cloudflare Turnstile (captcha en /registro) — Site Key pública.
# La Secret Key NO va acá: se carga como secreto de la Edge Function con
#   npx supabase secrets set TURNSTILE_SECRET_KEY=...
# Configurar también en Vercel → Project Settings → Environment Variables.
VITE_TURNSTILE_SITE_KEY=tu-turnstile-site-key
