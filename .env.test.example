# Config de smoke tests E2E (Playwright). Copiar a `.env.test` (fuera de git) y
# completar solo lo que necesites. Los tests que dependen de estas vars se
# saltan (test.skip) si no están seteadas — nunca hardcodear credenciales reales
# en el código de los tests.
#
# Nota: Playwright no carga `.env.test` automáticamente. Setealas en el entorno
# antes de correr, p. ej.:
#   PLAYWRIGHT_BASE_URL=http://localhost:5173 npm run test:e2e

# URL base contra la que corren los tests. Default: https://misillon.vercel.app
PLAYWRIGHT_BASE_URL=https://misillon.vercel.app

# Slug de una barbería APROBADA real con peluqueros activos, para el camino
# feliz del wizard de reserva. Si no se setea, ese test se salta y el smoke
# de reserva pública solo verifica que la ruta monte sin crash.
E2E_DEMO_SLUG=

# Credenciales de una cuenta demo (dueño/peluquero/independiente) para probar
# login real y carga del panel. Al 2026-07-04 no existe una cuenta demo
# confiable en producción — provisionar una dedicada antes de setear esto.
E2E_DEMO_EMAIL=
E2E_DEMO_PASSWORD=
